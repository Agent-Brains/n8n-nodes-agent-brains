		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"release:all": "bash scripts/release-all.sh",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"workspaces": [
		"packages/*"
	],
	"n8n": {},
	"devDependencies": {
		"@n8n/node-cli": "0.17.0",
