{
	"name": "n8n-nodes-agent-brains-monorepo",
	"private": true,
	"version": "1.11.0",
	"description": "AgentBrains nodes for n8n to integrate workflows, production webhooks, and Synthetic User validation with the AgentBrains platform.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"agent-brains",
		"agentbrains",
		"integration",
		"trigger",
		"webhook",
		"synthetic-users",
		"ai-employees",
		"knowledge-base",
		"entities",
		"categories",
		"attachments",
		"synthetic-users",
		"category-aliases"
	],
	"author": {
		"name": "Vlad Balabash",
		"email": "vbalabash@agent-brains.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Agent-Brains/n8n-nodes-agent-brains.git"
	},
	"scripts": {
		"postinstall": "node scripts/sync-shared.js",
		"sync": "node scripts/sync-shared.js",
		"build": "TARGET_ENV=${TARGET_ENV:-sandbox} n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
