{
	"name": "n8n-nodes-agent-brains",
	"version": "3.0.0",
	"description": "AgentBrains platform nodes for n8n",
	"license": "MIT",
	"homepage": "https://github.com/Agent-Brains/n8n-nodes-agent-brains",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"agent-brains",
		"knowledge-base",
		"employee",
		"rag",
		"synthetic-qa"
	],
	"author": {
		"name": "Vlad Balabash",
		"email": "vbalabash@agent-brains.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Agent-Brains/n8n-nodes-agent-brains.git",
		"directory": "packages/platform"
	},
	"scripts": {
		"prebuild": "node ../../scripts/sync-shared.js",
		"build": "tsc && node ../../scripts/copy-assets.js",
		"build:watch": "tsc --watch",
		"predev": "node ../../scripts/sync-shared.js",
		"dev": "n8n-node dev",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AgentBrainsIntegrationApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/KnowledgeBase/KnowledgeBase.node.js",
			"dist/nodes/Employee/AgentBrainsEmployee.node.js",
			"dist/nodes/RAG/AgentBrainsRag.node.js",
			"dist/nodes/SyntheticQa/SyntheticQa.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.17.0",
		"eslint": "9.32.0",
		"n8n-workflow": "2.15.0",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
